# ============================================================
#  .env.example — Modelo de configuração
#  Copie este arquivo para .env e preencha com seus valores reais.
#  NUNCA suba o arquivo .env para o GitHub.
# ============================================================

# ─── Azure AD / Microsoft Graph ─────────────────────────────
TENANT_ID=seu-tenant-id-aqui
CLIENT_ID=seu-client-id-aqui
CLIENT_SECRET=seu-client-secret-aqui

# ─── SharePoint ──────────────────────────────────────────────
# Formato: suaempresa.sharepoint.com:/sites/NomeDaSite
SHAREPOINT_SITE=suaempresa.sharepoint.com:/sites/NomeDaSite

# Caminho da pasta raiz dentro do SharePoint (sem barra inicial)
SHAREPOINT_BASE_FOLDER=Departamento/Clientes/EMPRESA/FATURAMENTO/CONTRATOS

# ─── E-mail remetente ────────────────────────────────────────
MAILBOX_REMETENTE=financeiro@suaempresa.com.br

# ─── Caminhos locais (relativos à pasta RPA_SINERGAS) ────────
# Planilha com dados dos clientes (nome, e-mail, região)
EXCEL_FILENAME=Base/EMAILS_CLIENTES.xlsx

# Imagem de cabeçalho do e-mail (opcional)
THUMBNAIL_FILENAME=Base/thumbnail.jpg
